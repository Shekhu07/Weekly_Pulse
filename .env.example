# Weekly Product Review Pulse — Environment Variables
# Copy this file to .env and fill in real values.

# === LLM (Groq — for theme summarization) ===
GROQ_API_KEY=gsk_your_groq_api_key_here

# === Embeddings ===
# Embeddings use BAAI/bge-small-en-v1.5 via sentence-transformers (local, no API key needed).
# The model (~80 MB) is downloaded once to your HuggingFace cache on first run.

# === MCP Server ===
MCP_SERVER_URL=http://localhost:8000

# === Optional Overrides ===
# PULSE_EMAIL_MODE=draft        # draft | send (overrides product config)
# PULSE_DRY_RUN=false           # true to skip MCP writes
